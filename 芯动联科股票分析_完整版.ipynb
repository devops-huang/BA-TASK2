   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print('\\n2.4 计算KDJ指标（扩展指标）...')\n",
    "\n",
    "# KDJ计算函数\n",
    "def calculate_kdj(df, period=9):\n",
    "    \"\"\"\n",
    "    计算KDJ指标\n",
    "    \n",
    "    参数:\n",
    "    - df: DataFrame，包含'high', 'low', 'close'列\n",
    "    - period: 周期，默认9天\n",
    "    \n",
    "    返回:\n",
    "    - df: 添加'KDJ_K', 'KDJ_D', 'KDJ_J'列的DataFrame\n",
    "    \"\"\"\n",
    "    # 计算RSV\n",
    "    low_list = df['low'].rolling(window=period).min()\n",
    "    high_list = df['high'].rolling(window=period).max()\n",
    "    \n",
    "    rsv = (df['close'] - low_list) / (high_list - low_list) * 100\n",
    "    \n",
    "    # 计算K值和D值（使用指数移动平均）\n",
    "    df['KDJ_K'] = rsv.ewm(com=2, adjust=False).mean()\n",
    "    df['KDJ_D'] = df['KDJ_K'].ewm(com=2, adjust=False).mean()\n",
    "    \n",
    "    # 计算J值\n",
    "    df['KDJ_J'] = 3 * df['KDJ_K'] - 2 * df['KDJ_D']\n",
    "    \n",
    "    return df\n",
    "\n",
    "# 计算KDJ\n",
    "df_stock = calculate_kdj(df_stock, period=9)\n",
    "\n",
    "print(f'✓ KDJ计算完成（周期=9天）')\n",
    "print(f'  当前K值: {df_stock[\"KDJ_K\"].iloc[-1]:.2f}')\n",
    "print(f'  当前D值: {df_stock[\"KDJ_D\"].iloc[-1]:.2f}')\n",
    "print(f'  当前J值: {df_stock[\"KDJ_J\"].iloc[-1]:.2f}')"
   ]
