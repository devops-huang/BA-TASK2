   "source": [
    "print('\\n2.3 计算布林带指标...')\n",
    "\n",
    "# 布林带计算函数\n",
    "def calculate_bollinger_bands(df, period=20, std_dev=2):\n",
    "    \"\"\"\n",
    "    计算布林带指标\n",
    "    \n",
    "    参数:\n",
    "    - df: DataFrame，包含'close'列\n",
    "    - period: 移动平均周期，默认20天\n",
    "    - std_dev: 标准差倍数，默认2倍\n",
    "    \n",
    "    返回:\n",
    "    - df: 添加'BB_upper', 'BB_middle', 'BB_lower'列的DataFrame\n",
    "    \"\"\"\n",
    "    # 计算中轨（MA）\n",
    "    df['BB_middle'] = df['close'].rolling(window=period).mean()\n",
    "    \n",
    "    # 计算标准差\n",
    "    std = df['close'].rolling(window=period).std()\n",
    "    \n",
    "    # 计算上轨和下轨\n",
    "    df['BB_upper'] = df['BB_middle'] + (std * std_dev)\n",
    "    df['BB_lower'] = df['BB_middle'] - (std * std_dev)\n",
    "    \n",
    "    # 计算布林带宽度（波动率指标）\n",
    "    df['BB_width'] = (df['BB_upper'] - df['BB_lower']) / df['BB_middle']\n",
    "    \n",
    "    return df\n",
    "\n",
    "# 计算布林带\n",
    "df_stock = calculate_bollinger_bands(df_stock, period=20, std_dev=2)\n",
    "\n",
    "print(f'✓ 布林带计算完成（周期=20天，标准差倍数=2）')\n",
    "print(f'  当前上轨: {df_stock[\"BB_upper\"].iloc[-1]:.2f}')\n",
    "print(f'  当前中轨: {df_stock[\"BB_middle\"].iloc[-1]:.2f}')\n",
    "print(f'  当前下轨: {df_stock[\"BB_lower\"].iloc[-1]:.2f}')\n",
    "print(f'  当前布林带宽度: {df_stock[\"BB_width\"].iloc[-1]:.4f}')"
   ]
